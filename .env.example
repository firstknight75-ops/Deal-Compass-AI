# Copy this file to .env for local development.
# Do not commit real secrets or deployment-specific values.

# Runtime
NODE_ENV=development

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="DealCompass AI+"
NEXT_PUBLIC_APP_VERSION=local

# Supabase
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Client-exposed Supabase values for Vite.
# Only publishable/anon keys belong in VITE_* variables.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Redis / Upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Feature flags
FEATURE_FLAG_CRAWLER=false
FEATURE_FLAG_TRADE_FINANCE=false
FEATURE_FLAG_COMPLIANCE=false
FEATURE_FLAG_KNOWLEDGE_GRAPH=false
